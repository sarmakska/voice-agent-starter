{
  "name": "voice-agent-starter",
  "version": "1.1.0",
  "private": true,
  "description": "Real-time full-duplex voice agent loop on Fastify and Next.js. Pluggable streaming STT, LLM, and TTS adapters with barge-in and function-call passthrough.",
  "license": "MIT",
  "author": "Sarma Linux <https://sarmalinux.com>",
  "homepage": "https://github.com/sarmakska/voice-agent-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarmakska/voice-agent-starter.git"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "lint": "eslint apps/server/src apps/web/app",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "typescript-eslint": "^8.61.0"
  }
}
