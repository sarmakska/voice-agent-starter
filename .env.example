# Provider selection. The defaults are the self-hosted, open-source stack:
# Groq Llama 4 for the LLM, Whisper.cpp for STT, OpenTTS Coqui XTTS v2 for TTS.
STT_PROVIDER=whispercpp   # whispercpp | deepgram | whisper
LLM_PROVIDER=groq         # groq | sarmalink | openai
TTS_PROVIDER=opentts      # opentts | cartesia | elevenlabs

# Groq Llama 4 LLM (default). https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Whisper.cpp self-hosted STT (default). Point at a running whisper-server.
WHISPERCPP_URL=http://localhost:8090

# OpenTTS self-hosted TTS (default). Coqui XTTS v2 voices.
OPENTTS_URL=http://localhost:5500
OPENTTS_VOICE=coqui-tts:en_vctk#xtts_v2

# Alternative LLM providers
SARMALINK_API_KEY=
SARMALINK_MODEL=fast
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Alternative STT / TTS providers
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
WHISPER_MODEL=whisper-1
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Server
SERVER_PORT=3001
LOG_LEVEL=info

# Web
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
